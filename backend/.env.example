# LeadPulse environment configuration — copy to `.env` and fill in.
# NEVER commit a real `.env`. All secrets come from here (single trust root).

# ---- Application ----
APP_NAME=LeadPulse
APP_ENV=development          # development | staging | production
APP_PORT=8000
LOG_LEVEL=INFO

# ---- Database ----
# Component vars are the source of truth; DATABASE_URL is derived from them
# when left blank. In Docker Compose use the service name as the host.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=leadpulse
POSTGRES_HOST=localhost       # use `postgres` under docker-compose
POSTGRES_PORT=5432
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/leadpulse

# ---- Redis ----
REDIS_HOST=localhost          # use `redis` under docker-compose
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL=redis://localhost:6379/0

# ---- Security (REQUIRED in non-dev; app refuses to boot without them) ----
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=dev-only-insecure-key-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

# ---- CORS (comma-separated origins; do not use * in production) ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- LLM provider ----
GROQ_API_KEY=your-groq-api-key
LLM_MODEL=llama3-70b-8192

# ---- Email (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@leadpulse.example

# ---- Outbound webhook (optional) ----
WEBHOOK_URL=

# ---- Rate limiting ----
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_INGEST_PER_MINUTE=60

# ---- Observability (optional) ----
SENTRY_DSN=
